# ── Clés API ──────────────────────────────────────────
GITHUB_TOKEN=ghp_xxx
GROQ_API_KEY=gsk_xxx

# ── LLM ───────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
# Modèle vision (images jointes) — fallback qwen/qwen3.6-27b si indisponible
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Génération d'images : auto | pollinations | openai | off
# auto = OpenAI si OPENAI_API_KEY, sinon Pollinations (gratuit, sans clé)
IMAGE_GEN_PROVIDER=auto
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=dall-e-3
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.95
LLM_PRESENCE_PENALTY=0
LLM_FREQUENCY_PENALTY=0.2
MAX_TOKENS=3000
MAX_HISTORIQUE=8
MAX_HISTORIQUE_LEGER=6

# ── Embeddings / Reranking ────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Qdrant ────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=github_docs
QDRANT_URL=http://localhost:6333

# ── Comptes & admin AssistDoc ─────────────────────────
# Admin seed (créé automatiquement au 1er lancement)
ADMIN_EMAIL=admin@assistdoc.local
ADMIN_PASSWORD=changez_moi
# Compat ancienne auth (utilisée comme mdp admin si ADMIN_PASSWORD vide)
STREAMLIT_PASSWORD=
ADMIN_USERS=admin
# SHOW_ADMIN_CORPUS=0

# Quotas quotidiens (requêtes chat)
QUOTA_GUEST_REQ=12
QUOTA_EMAIL_REQ=80
QUOTA_GITHUB_REQ=200
QUOTA_GOOGLE_REQ=120
QUOTA_GUEST_MIN=30
QUOTA_EMAIL_MIN=180
QUOTA_GITHUB_MIN=480
QUOTA_GOOGLE_MIN=360

# GitHub OAuth (optionnel — bouton activé seulement si renseigné)
# Créer une OAuth App : https://github.com/settings/developers
# Callback : http://localhost:8501/
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:8501/

# Google OAuth (optionnel — bouton « Continuer avec Google »)
# Console : https://console.cloud.google.com/apis/credentials
# Type : Application Web — URI de redirection autorisée :
#   http://localhost:8501/
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501/

# Apple Sign In (optionnel — compte Apple Developer payant requis)
# 1. Certificates, Identifiers & Profiles → Keys → Sign in with Apple (.p8)
# 2. Identifiers → Services ID (ex. com.assistdoc.web) + domaines / redirect
# Redirect Apple (form_post) → API FastAPI :
#   http://localhost:8000/auth/apple/callback
# Puis l'API renvoie vers Streamlit (STREAMLIT_PUBLIC_URL).
# APPLE_OAUTH_CLIENT_ID=com.assistdoc.web
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PATH=secrets/AuthKey_XXXXX.p8
# # ou APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APPLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/apple/callback
# STREAMLIT_PUBLIC_URL=http://localhost:8501/
# QUOTA_APPLE_REQ=120
# QUOTA_APPLE_MIN=360

# Taille max upload (octets) — défaut 10 Mo
UPLOAD_MAX_BYTES=10485760

# ── Sécurité API FastAPI ──────────────────────────────
# Clés API : cle1:owner1,cle2:owner2 (vide = accès libre en local)
# API_KEYS=
# Secret pour POST /ingest/webhook (header X-Ingest-Secret)
# INGEST_WEBHOOK_SECRET=

# ── Options runtime ───────────────────────────────────
# DESACTIVER_WEB_SEARCH=true
# MODE_RAGAS_EVAL=false
# WEB_TIMEOUT=5
# DISABLE_SSL_VERIFY=1   # dépannage proxy uniquement — JAMAIS en prod
